<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#43A047"></stop>
      <stop offset="1" stop-color="#1B5E20"></stop>
    </linearGradient>
    <linearGradient id="leaf" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#E8F5E9"></stop>
      <stop offset="1" stop-color="#A5D6A7"></stop>
    </linearGradient>
  </defs>

  <!-- 圆角底板 -->
  <rect width="512" height="512" rx="110" fill="url(#bg)"></rect>

  <!-- 茎 -->
  <path d="M256 420 C256 360 256 300 256 150" stroke="#2E7D32" stroke-width="14" stroke-linecap="round" fill="none"></path>

  <!-- 主叶片 -->
  <path d="M256 150
           C150 170 120 280 160 360
           C220 340 280 280 290 200
           C288 180 274 160 256 150 Z" fill="url(#leaf)"></path>
  <path d="M256 150
           C362 170 392 280 352 360
           C292 340 232 280 222 200
           C224 180 238 160 256 150 Z" fill="url(#leaf)" opacity="0.95"></path>

  <!-- 叶脉 -->
  <path d="M256 160 C230 240 200 300 175 345" stroke="#66BB6A" stroke-width="6" stroke-linecap="round" fill="none"></path>
  <path d="M256 160 C282 240 312 300 337 345" stroke="#66BB6A" stroke-width="6" stroke-linecap="round" fill="none"></path>
  <path d="M256 160 C256 250 256 320 256 380" stroke="#4CAF50" stroke-width="6" stroke-linecap="round" fill="none"></path>

  <!-- 小露珠点缀 -->
  <circle cx="205" cy="275" r="10" fill="#FFFFFF" opacity="0.55"></circle>
  <circle cx="315" cy="255" r="7" fill="#FFFFFF" opacity="0.45"></circle>
</svg>